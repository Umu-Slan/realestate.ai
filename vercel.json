{
  "version": 2,
  "buildCommand": "python manage.py collectstatic --noinput",
  "builds": [
    {
      "src": "public/**",
      "use": "@vercel/static"
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "rewrites": [
    {
      "source": "/",
      "destination": "/api/engines/demo/"
    }
  ],
  "routes": [
    {
      "src": "/((?!static/).*)",
      "dest": "/api/index.py"
    }
  ]
}
