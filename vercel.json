{
  "version": 2,
  "builds": [
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "api/index.py"
    }
  ],
  "redirects": [
    {
      "source": "/",
      "destination": "/api/engines/demo/",
      "permanent": false
    }
  ]
}
