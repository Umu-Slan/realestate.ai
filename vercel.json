{
  "version": 2,
  "buildCommand": "python manage.py collectstatic --noinput",
  "functions": {
    "api/index.py": {
      "maxDuration": 10
    }
  },
  "builds": [
    {
      "src": "public/**",
      "use": "@vercel/static"
    },
    {
      "src": "api/index.py",
      "use": "@vercel/python"
    }
  ],
  "routes": [
    {
      "src": "/((?!static/).*)",
      "dest": "api/index.py"
    }
  ]
}
