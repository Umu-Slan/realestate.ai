# Real Estate AI v0 - Environment Template
# Copy to .env and adjust for your environment
#   copy .env.example .env

# RECOMMENDED: Docker-based local (no host PostgreSQL needed)
#   1. docker compose up -d
#   2. copy .env.example .env  (these values work as-is)
# Required: PostgreSQL with pgvector (Docker uses 5433 to avoid host conflict on 5432)
# Format: postgresql://USER:PASSWORD@HOST:PORT/DATABASE
DATABASE_URL=postgresql://realestate_dev:realestate_dev_pass@localhost:5433/realestate_ai

# Redis (Docker provides this on port 6380 to avoid host conflicts)
CELERY_BROKER_URL=redis://localhost:6380/1
REDIS_URL=redis://localhost:6380/0

# Optional: OpenAI (set DEMO_MODE=true to use mock LLM)
OPENAI_API_KEY=sk-...
LLM_MODEL=gpt-4o-mini
# Seconds — prevents hung HTTP calls to OpenAI (intent + composer)
LLM_TIMEOUT_SECONDS=30
EMBEDDING_MODEL=text-embedding-3-small

# Optional: Tesseract OCR for image uploads (JPG/PNG). If tesseract is not on PATH, set full path to tesseract.exe
# TESSERACT_CMD=C:/Program Files/Tesseract-OCR/tesseract.exe

# Demo mode: uses mock LLM, no API calls
DEMO_MODE=true

# Django (PRODUCTION: override all three)
# Production: SECRET_KEY from `python -c "import secrets; print(secrets.token_urlsafe(50))"`
SECRET_KEY=change-this-in-production
DEBUG=true
ALLOWED_HOSTS=localhost,127.0.0.1

# Production: set DJANGO_ENV=production, DJANGO_SETTINGS_MODULE=config.settings_production

# Vercel / empty DB demos: create sample Recommendation rows on first visit to /console/recommendations/
# (otherwise that page and Lead intelligence charts stay empty until real chats run).
# ALLOW_SAMPLE_RECOMMENDATIONS=1

# HTTPS deploys: add your site origin for login/forms, e.g.
# CSRF_TRUSTED_ORIGINS=https://your-app.vercel.app,https://yourdomain.com

# WhatsApp webhook verification (Meta)
# WHATSAPP_VERIFY_TOKEN=

# POST /api/channels/inbound/ — Telegram, Meta DMs, SMS gateways (Bearer or X-API-Key)
# CHANNEL_INBOUND_API_KEY=
