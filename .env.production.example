# Production environment template
# Copy to .env when deploying. Never commit .env with real secrets.

# REQUIRED - Change for production
SECRET_KEY=generate-with-python-c-import-secrets-print-secrets-token_urlsafe-50
ALLOWED_HOSTS=your-domain.com,www.your-domain.com,localhost

# REQUIRED - Database (matches docker-compose.production postgres)
DATABASE_URL=postgresql://realestate:YOUR_POSTGRES_PASSWORD@postgres:5432/realestate_ai
POSTGRES_PASSWORD=YOUR_POSTGRES_PASSWORD

# REQUIRED - Redis (matches docker-compose.production redis)
CELERY_BROKER_URL=redis://redis:6379/1
REDIS_URL=redis://redis:6379/0

# Production flags
DEBUG=false
DJANGO_ENV=production

# Optional - CORS (comma-separated origins when DEBUG=false)
CORS_ALLOWED_ORIGINS=https://your-domain.com

# Optional - CSRF trusted origins (required for HTTPS + form/AJAX from these origins)
# Comma-separated: https://your-domain.com,https://www.your-domain.com
CSRF_TRUSTED_ORIGINS=https://your-domain.com,https://www.your-domain.com

# Optional - Upload limits (default 10MB for operator docs/CSV)
FILE_UPLOAD_MAX_MEMORY_SIZE=10485760

# Optional - OpenAI (set DEMO_MODE=false for live LLM)
OPENAI_API_KEY=sk-...
DEMO_MODE=false

# Optional - Backup manifest identification
COMPANY_NAME=

# Optional - WhatsApp
WHATSAPP_VERIFY_TOKEN=
